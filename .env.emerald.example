# Example environment file for Emerald integration tests.
# Copy to .env.emerald and adjust values.
#
# Usage:
#   ./scripts/run-emerald-tests.sh --env-file .env.emerald
#
# See also:
#   ~/Documents/build-whatever/Emerald/docs/superpowers/specs/2026-05-27-emerald-v0.2.0-quickstart.md

# ---------------------------------------------------------------------------
# Memory mode (default, fastest — no Docker needed)
# ---------------------------------------------------------------------------
EMERALD_BASE_URL=http://localhost:9999
EMERALD_API_KEY=em_test

# Path to Emerald repo (for memory mode auto-start)
# If unset, the script looks for Emerald at ~/Documents/build-whatever/Emerald
# EMERALD_REPO=/path/to/emerald

# ---------------------------------------------------------------------------
# Docker mode (full stack — requires Docker)
# Uncomment to use Docker Compose instead of memory mode.
# ---------------------------------------------------------------------------
# EMERALD_BASE_URL=http://localhost:8000
# EMERALD_API_KEY=em_dev
# EMERALD_IMAGE=emerald:v0.2.0
# EMERALD_PORT=8000
