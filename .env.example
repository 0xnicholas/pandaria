# Pandaria environment variables
# Copy this file to .env and fill in your actual API keys.

# =============================================================================
# Server Config
# =============================================================================

# Server HMAC auth secret (used to sign/verify tokens).
# Required in production. Defaults to a dev secret for local development.
PANDARIA_AUTH_SECRET=change-me-in-production

# Bind address (default: 0.0.0.0:8080)
# PANDARIA_BIND_ADDR=0.0.0.0:8080

# =============================================================================
# Runtime Config (model, prompt, compaction)
# =============================================================================

# Default model for new sessions (default: deepseek/deepseek-v4-pro)
# PANDARIA_DEFAULT_MODEL=deepseek/deepseek-v4-pro

# Default system prompt (default: "You are a helpful assistant.")
# PANDARIA_DEFAULT_SYSTEM_PROMPT=You are a helpful assistant.

# Comma-separated list of available models (default: same as default model)
# PANDARIA_AVAILABLE_MODELS=deepseek/deepseek-v4-flash,deepseek/deepseek-v4-pro

# Compaction settings
# PANDARIA_COMPACTION_ENABLED=true
# PANDARIA_COMPACTION_RESERVE_TOKENS=4096
# PANDARIA_COMPACTION_KEEP_RECENT_TOKENS=8192

# =============================================================================
# Dev Tenant (auto-registered at startup when PANDARIA_DEV_TENANT is set)
# =============================================================================

# PANDARIA_DEV_TENANT=test-tenant
# PANDARIA_DEV_TENANT_MAX_SESSIONS=10
# PANDARIA_DEV_TENANT_MAX_TOKENS=1000000
# PANDARIA_DEV_TENANT_MAX_TOOL_CALLS=60
# PANDARIA_DEV_TENANT_CPU_BUDGET_MS=3600000

# =============================================================================
# LLM Provider API Keys (at least one required)
# =============================================================================

# DeepSeek API key
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# OpenAI API key
# OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API key
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google API key
# GOOGLE_API_KEY=your-google-api-key-here

# Mistral API key
# MISTRAL_API_KEY=your-mistral-api-key-here

# Doubao API key
# DOUBAO_API_KEY=your-doubao-api-key-here

# OpenRouter API key
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Mimo API key
# MIMO_API_KEY=your-mimo-api-key-here
